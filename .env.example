# =============================================================================
# MISTRAL AI - LLM for Farming Advice
# =============================================================================
# Get your API key from: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here

# =============================================================================
# SARVAM AI - Text-to-Speech (Hindi, Kannada, English)
# =============================================================================
# Get your API key from: https://sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=file:./dev.db

# =============================================================================
# WEATHER DATA - Choose one or all for automatic fallback
# =============================================================================

# Option 1: WeatherAPI.com (RECOMMENDED - Best structured data)
# Sign up at: https://www.weatherapi.com/
# Free tier includes: Current weather, 10-day forecast, Real-time alerts
# Used as first priority if key is provided
WEATHER_API_KEY=

# Option 2: Tomorrow.io (Advanced weather data)
# Sign up at: https://www.tomorrow.io/weather-api/
# Free tier includes: Detailed hourly forecasts, Air quality, Pollen
# Used as second priority if key is provided
TOMORROW_IO_API_KEY=

# Option 3: Open-Meteo (Completely FREE - No API key needed!)
# Website: https://open-meteo.com/
# No registration required, no API key needed
# Provides: Current weather, forecasts, historical data
# Used as fallback - always available
OPEN_METEO_ENABLED=true

# =============================================================================
# MARKET DATA & SOIL DATA
# =============================================================================
# Agmarknet: https://agmarknet.gov.in/ (Mandi prices via web scraping)
AGMARKNET_ENABLED=true

# SoilGrids: https://www.isric.org/explore/soilgrids (Soil properties via API)
SOILGRIDS_ENABLED=true

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file to .env.local
# 2. Add your actual API keys for Mistral and Sarvam
# 3. For weather, at minimum use Open-Meteo (free, no key needed)
# 4. (Optional) Add WeatherAPI key from https://www.weatherapi.com/ for better data
# 5. Test with: npm run dev
# 
# WEATHER PRIORITY ORDER (auto-fallback if previous fails):
#   1. WeatherAPI.com (if WEATHER_API_KEY provided)
#   2. Tomorrow.io (if TOMORROW_IO_API_KEY provided)  
#   3. Open-Meteo (always available, completely FREE)
# ==============================================================================
